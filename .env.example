# GID of the i2c group on your host: stat /dev/i2c-1 | grep Gid
I2C_GID=994

INFLUX_URL=https://your-influxdb-host
INFLUX_TOKEN=your-token-here
INFLUX_ORG=your-org
INFLUX_BUCKET=scd41

# Optional tuning
INTERVAL_SEC=10
LOG_LEVEL=INFO
INFLUX_BATCH_SIZE=6
INFLUX_FLUSH_MS=60000

# Optional location tag
# LOCATION=livingRoom
